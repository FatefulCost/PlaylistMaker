<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/playlist_background">

    <!-- Верхняя часть с обложкой и информацией (статичная) -->
    <LinearLayout
        android:id="@+id/topContentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <!-- Кнопка назад -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/arrow"
                app:tint="@color/search_text_color" />

        </FrameLayout>

        <!-- Обложка плейлиста -->
        <androidx.cardview.widget.CardView
            android:id="@+id/playlistCoverCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/playlistCoverImageView"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerCrop"
                    android:background="@color/playlist_background"
                    android:src="@drawable/vector_placeholder"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <!-- Информация о плейлисте -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/playlistNameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlist_name_in_list"
                android:textSize="24sp"
                android:textColor="@color/search_text_color"
                android:fontFamily="@font/ys_display_bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/playlistDescriptionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2022"
                android:textSize="18sp"
                android:textColor="@color/search_text_color"
                android:fontFamily="@font/ys_display_regular"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/totalDurationValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 минут"
                    android:textSize="18sp"
                    android:textColor="@color/search_text_color"
                    android:fontFamily="@font/ys_display_regular" />

                <TextView
                    android:id="@+id/separatorDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="•"
                    android:textSize="13sp"
                    android:textColor="@color/search_text_color" />

                <TextView
                    android:id="@+id/playlistTracksCountTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/track_count"
                    android:textSize="18sp"
                    android:textColor="@color/search_text_color"
                    android:fontFamily="@font/ys_display_regular" />

            </LinearLayout>

            <!-- Кнопки Поделиться и Меню -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginBottom="16dp">

                <ImageButton
                    android:id="@+id/shareButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/vector_share"
                    android:contentDescription="@string/menu_share"
                    app:tint="@color/search_text_color" />

                <ImageButton
                    android:id="@+id/menuButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_menu"
                    app:tint="@color/search_text_color" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Нижняя часть со списком треков (прокручиваемая) -->
    <LinearLayout
        android:id="@+id/bottomSheetLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_background"
        app:layout_constraintTop_toBottomOf="@id/topContentLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Индикатор -->
        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bottom_sheet_indicator"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:text="@string/tracks_list"
            android:textSize="19sp"
            android:textColor="@color/history_text_color"
            android:fontFamily="@font/ys_display_medium"
            android:layout_marginBottom="16dp" />

        <!-- Список треков с прокруткой -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tracksRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

        <!-- Пустое состояние для списка треков -->
        <LinearLayout
            android:id="@+id/emptyTracksLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="32dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_tracks_in_playlist"
                android:textSize="16sp"
                android:textColor="@color/song_details_color"
                android:fontFamily="@font/ys_display_regular" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>