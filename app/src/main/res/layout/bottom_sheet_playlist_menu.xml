<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/back_ground_color_settings"
    android:paddingTop="16dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Индикатор (полоска сверху) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/song_details_color"
        android:layout_marginBottom="16dp" />

    <!-- Информация о плейлисте -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- Обложка плейлиста -->
        <androidx.cardview.widget.CardView
            android:id="@+id/playlistCoverCardView"
            android:layout_width="45dp"
            android:layout_height="45dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/playlistCoverImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/placeholder_background"
                android:src="@drawable/vector_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- Информация -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/playlistNameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/playlist_name_in_list"
                android:textSize="16sp"
                android:textColor="@color/history_text_color"
                android:fontFamily="@font/ys_display_medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/playlistTracksCountTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/track_count"
                android:textSize="11sp"
                android:textColor="@color/song_details_color_in_sheet"
                android:fontFamily="@font/ys_display_regular" />

        </LinearLayout>

    </LinearLayout>

    <!-- Меню -->
    <LinearLayout
        android:id="@+id/menuShare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_share"
            android:textSize="16sp"
            android:textColor="@color/history_text_color"
            android:fontFamily="@font/ys_display_regular" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_edit"
            android:textSize="16sp"
            android:textColor="@color/history_text_color"
            android:fontFamily="@font/ys_display_regular" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_delete"
            android:textSize="16sp"
            android:textColor="@color/history_text_color"
            android:fontFamily="@font/ys_display_regular" />

    </LinearLayout>

</LinearLayout>