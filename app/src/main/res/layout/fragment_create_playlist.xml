<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/back_ground_color_settings">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/new_playlist"
        app:navigationIcon="@drawable/arrow"
        style="@style/CustomToolbarStyleSettings" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Область для обложки -->
            <FrameLayout
                android:id="@+id/cover_container"
                android:layout_width="match_parent"
                android:layout_height="312dp"
                android:layout_gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true">

                <!-- Пунктирная рамка -->
                <View
                    android:id="@+id/lines_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/dashed_border" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/coverCardView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/cover_image_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                </androidx.cardview.widget.CardView>

                <!-- Иконка добавления фото -->
                <LinearLayout
                    android:id="@+id/add_photo_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/ic_add_photo" />

                </LinearLayout>

            </FrameLayout>

            <!-- Поле для названия -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/name_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/text_input_layout_selector"
                android:textColorHint="@color/playlist_name"
                app:hintTextColor="@color/playlist_hint_when_clicked">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/playlist_name_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/playlist_name"
                    android:maxLines="1"
                    android:inputType="text"
                    android:textColor="@color/playlist_name"
                    android:textColorHint="@color/playlist_description" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Поле для описания -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/description_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/text_input_layout_selector"
                android:textColorHint="@color/playlist_name"
                app:hintTextColor="@color/playlist_hint_when_clicked">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/playlist_description_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/playlist_description"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:textColor="@color/history_text_color"
                    android:textColorHint="@color/song_details_color" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="17dp"
        android:layout_marginBottom="10dp"
        android:text="@string/create"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:enabled="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/create_button_selector"
        app:cornerRadius="8dp"
        android:fontFamily="@font/ys_display_medium"/>

</LinearLayout>